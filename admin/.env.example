# EverNode admin — local-only configuration.
# This template is committed; the real file lives at ../.env.admin (gitignored).
# Run `npm run admin:setup` to create and populate the real file.

# Required. Minimum 12 characters.
ADMIN_PASSWORD=change-me-locally-please

# Optional. Default 5174.
ADMIN_PORT=5174

# Optional. Default "main".
ADMIN_GIT_BRANCH=main

# Optional. Default "origin".
ADMIN_GIT_REMOTE=origin

# Optional. Set to 1 to honor commit.gpgsign from your git config.
# Default (unset): publish disables signing for unattended commits.
# ADMIN_GIT_SIGN=1
